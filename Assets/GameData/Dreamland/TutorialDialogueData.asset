  m_Script: {fileID: 11500000, guid: af3b96ad2529086478b5f219979d7bbe, type: 3}
  m_Name: TutorialDialogueData
  m_EditorClassIdentifier: Assembly-CSharp::DreamGuardians.TutorialDialogueData
  missionStartTitle: MISSION START
  missionStartSubtitle: "\uAFC8\uBE5B \uBB34\uAE30 \uD6C8\uB828"
  missionStartDuration: 2
  introLines:
  - speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uAFC8\uB098\uB77C \uC218\uD638\uB300\uC5D0 \uC628 \uAC78 \uD658\uC601\uD574!"
    duration: 2.5
  - speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uC800 \uBE5B\uB098\uB294 \uACF3\uC774 \uC6B0\uB9AC\uAC00 \uC9C0\uCF1C\uC57C
      \uD560 \uAFC8\uBE5B \uCF54\uC5B4\uC57C."
    duration: 3
  - speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uC190\uC5D0 \uB4E0 \uAFC8\uBE5B \uBB34\uAE30\uB85C \uB098\uD0C0\uB098\uB294
      \uC545\uBABD\uC744 \uB9DE\uD600\uBCF4\uC790!"
    duration: 3
  enemyAppearsLine:
    speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uC815\uBA74 \uC131 \uCABD\uC744 \uBD10! \uBC14\uB2E5\uC758 \uC791\uC740
      \uADE0\uC5F4\uC5D0\uC11C \uC5F0\uC2B5\uC6A9 \uC545\uBABD\uC774 \uB098\uD0C0\uB0A0
      \uAC70\uC57C."
    duration: 3
  shootingObjective: "\uD29C\uD1A0\uB9AC\uC5BC \uBAAC\uC2A4\uD130\uB97C \uBA85\uC911"
  shootingInstructionLine:
    speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uC870\uC900\uD55C \uB4A4 \uC545\uBABD\uC744 \uC138 \uBC88 \uB9DE\uD600\uBD10!"
    duration: 2.5
  synergyObjective: "\uB450 \uAC00\uC9C0 \uC9C1\uC5C5 \uC2DC\uB108\uC9C0\uB97C \uBC1C\uB3D9"
  synergyInstructionLine:
    speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uC798\uD588\uC5B4! \uC774\uC81C \uACBD\uCC30\uACFC \uC18C\uBC29\uAD00,
      \uCC9C\uBB38\uD559\uC790\uC640 \uAC74\uCD95\uAC00\uC758 \uAFC8\uBE5B\uC744
      \uAC01\uAC01 \uC774\uC5B4\uBCF4\uC790!"
    duration: 4
  purificationObjective: "\uBAA8\uB450 \uD568\uAED8 \uC545\uBABD\uC744 \uC815\uD654"
  purificationProgress: "\uBAAC\uC2A4\uD130 HP\uB97C 0\uC73C\uB85C \uB9CC\uB4DC\uC138\uC694"
  purificationInstructionLine:
    speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uC88B\uC544! \uC774\uC81C \uBAA8\uB450 \uD568\uAED8 \uC545\uBABD\uC744
      \uC644\uC804\uD788 \uC815\uD654\uD574\uBCF4\uC790!"
    duration: 3
  tutorialClearTitle: TUTORIAL CLEAR
  tutorialClearSubtitle: "\uAFC8\uBE5B \uC5D0\uB108\uC9C0\uAC00 \uCF54\uC5B4\uB85C
    \uB3CC\uC544\uC654\uC2B5\uB2C8\uB2E4"
  tutorialClearDuration: 2
  tutorialClearLine:
    speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uC644\uBCBD\uD574! \uC774\uC81C \uBAB0\uB824\uC624\uB294 \uC545\uBABD\uB4E4\uB85C\uBD80\uD130
      \uAFC8\uBE5B \uCF54\uC5B4\uB97C \uC9C0\uCF1C\uC918!"
    duration: 3
  waveStartTitle: WAVE 1 START
  waveStartSubtitle: "\uAFC8\uBE5B \uCF54\uC5B4\uB97C \uC9C0\uCF1C\uB77C"
  waveObjective: "Stage 1 \xB7 \uCF54\uC5B4 \uBC29\uC5B4"
  afterFirstGroupLine:
    speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uC8FC\uBCC0\uC758 \uAFC8\uC774 \uBCC0\uD558\uACE0 \uC788\uC5B4. \uB2E4\uC74C
      \uACF5\uACA9\uC744 \uC900\uBE44\uD574!"
    duration: 3
  beforeFinalGroupLine:
    speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uADE0\uC5F4\uC774 \uB354 \uCEE4\uC84C\uC5B4. \uB9C8\uC9C0\uB9C9 \uACF5\uACA9\uC774
      \uC62C \uAC70\uC57C!"
    duration: 3
  waveClearTitle: WAVE 1 CLEAR
  waveClearSubtitle: "\uAFC8\uBE5B \uCF54\uC5B4 \uBC29\uC5B4 \uC131\uACF5"
  coreUpgradeTitle: CORE UPGRADE
  coreUpgradeSubtitle: "\uAFC8\uBE5B \uCF54\uC5B4\uAC00 \uBB34\uAE30\uB97C \uAC15\uD654\uD569\uB2C8\uB2E4"
  coreUpgradeLine:
    speaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
    message: "\uCF54\uC5B4\uAC00 \uB418\uCC3E\uC740 \uAFC8\uBE5B\uC73C\uB85C \uBB34\uAE30\uB97C
      \uAC15\uD654\uD558\uACE0 \uC788\uC5B4!"
    duration: 3
  missionFailedTitle: MISSION FAILED
  missionFailedSubtitle: "\uAFC8\uBE5B \uCF54\uC5B4\uAC00 \uBB34\uB108\uC84C\uC2B5\uB2C8\uB2E4"
