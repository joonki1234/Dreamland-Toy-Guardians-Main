  secondWaveTitle: "2\uCC28 \uCE68\uC2DD"
  finalWaveTitle: FINAL ATTACK
  finalPhaseTitle: FINAL PHASE
  finalPhaseSubtitle: "\uB0A8\uC740 \uC545\uBABD\uC744 \uBAA8\uB450 \uC815\uD654\uD558\uB77C"
  waveBannerDuration: 1.5
  progressRefreshInterval: 0.2
  clearTitle: STAGE 2 CLEAR
  clearSubtitle: "\uAFC8\uC758 \uADE0\uC5F4\uC774 \uC57D\uD574\uC84C\uC2B5\uB2C8\uB2E4"
  clearSpeaker: "\uC7A5\uB09C\uAC10 \uCE5C\uAD6C"
  clearMessage: "\uD574\uB0C8\uC5B4! \uB0A8\uC740 \uAFC8\uBE5B\uC774 \uD558\uB098\uB85C
